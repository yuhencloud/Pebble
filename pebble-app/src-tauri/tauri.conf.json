{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pebble",
  "identifier": "app.pebble.monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run build:bridge"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Pebble",
        "width": 324,
        "height": 50,
        "acceptFirstMouse": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "skipTaskbar": true,
        "visible": true,
        "focus": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
