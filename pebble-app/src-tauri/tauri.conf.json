{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pebble",
  "identifier": "app.pebble.monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pebble",
        "width": 280,
        "height": 400,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "shadow": false,
        "skipTaskbar": true,
        "visible": true,
        "focus": false,
        "center": false,
        "x": 1000,
        "y": 40
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
